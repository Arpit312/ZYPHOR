# MUST match website JWT_SECRET - enables cross-platform login!
JWT_SECRET=replace_with_long_random_secret_same_as_website

# Same MongoDB as website - shared database!
MONGODB_URI=mongodb://127.0.0.1:27017/zyphor

PORT=5000

# ─── AI (Google Gemini) ──────────────────────────────────────────
# IMPORTANT: aiRoutes.js calls the Gemini REST API directly (fetch to
# generativelanguage.googleapis.com). GEMINI_API_KEY is the one that's
# actually used. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── IMAGES (Cloudinary - free tier) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── PAYMENTS (optional, not yet wired into any route) ───────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

NODE_ENV=development
